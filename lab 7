#include <stdio.h>

#define MAX 50

void show(int f[], int m) {
    for (int i = 0; i < m; i++)
        if (f[i] == -1) printf("- ");
        else printf("%d ", f[i]);
}

int present(int f[], int m, int p) {
    for (int i = 0; i < m; i++)
        if (f[i] == p) return i;
    return -1;
}

void fifo(int p[], int n, int m) {
    int f[MAX], pos = 0, faults = 0, hits = 0;

    for (int i = 0; i < m; i++) f[i] = -1;

    printf("\nFIFO PAGE REPLACEMENT\n");
    printf("Page\tFrames\t\tStatus\n");

    for (int i = 0; i < n; i++) {
        if (present(f, m, p[i]) != -1) {
            hits++;
            printf("%d\t", p[i]);
            show(f, m);
            printf("\tHit\n");
        } else {
            f[pos] = p[i];
            pos = (pos + 1) % m;
            faults++;
            printf("%d\t", p[i]);
            show(f, m);
            printf("\tFault\n");
        }
    }

    printf("Page Faults = %d\tHits = %d\n", faults, hits);
}

void lru(int p[], int n, int m) {
    int f[MAX], time[MAX], count = 0, faults = 0, hits = 0;

    for (int i = 0; i < m; i++) {
        f[i] = -1;
        time[i] = 0;
    }

    printf("\nLRU PAGE REPLACEMENT\n");
    printf("Page\tFrames\t\tStatus\n");

    for (int i = 0; i < n; i++) {
        int x = present(f, m, p[i]);

        if (x != -1) {
            hits++;
            time[x] = ++count;
            printf("%d\t", p[i]);
            show(f, m);
            printf("\tHit\n");
        } else {
            int pos = 0;

            for (int j = 0; j < m; j++) {
                if (f[j] == -1) {
                    pos = j;
                    break;
                }
                if (time[j] < time[pos]) pos = j;
            }

            f[pos] = p[i];
            time[pos] = ++count;
            faults++;

            printf("%d\t", p[i]);
            show(f, m);
            printf("\tFault\n");
        }
    }

    printf("Page Faults = %d\tHits = %d\n", faults, hits);
}

void optimal(int p[], int n, int m) {
    int f[MAX], faults = 0, hits = 0;

    for (int i = 0; i < m; i++) f[i] = -1;

    printf("\nOPTIMAL PAGE REPLACEMENT\n");
    printf("Page\tFrames\t\tStatus\n");

    for (int i = 0; i < n; i++) {
        if (present(f, m, p[i]) != -1) {
            hits++;
            printf("%d\t", p[i]);
            show(f, m);
            printf("\tHit\n");
        } else {
            int pos = -1, far = -1;

            for (int j = 0; j < m; j++) {
                if (f[j] == -1) {
                    pos = j;
                    break;
                }

                int k;
                for (k = i + 1; k < n; k++)
                    if (f[j] == p[k]) break;

                if (k > far) {
                    far = k;
                    pos = j;
                }
            }

            f[pos] = p[i];
            faults++;

            printf("%d\t", p[i]);
            show(f, m);
            printf("\tFault\n");
        }
    }

    printf("Page Faults = %d\tHits = %d\n", faults, hits);
}

int main() {
    int p[MAX], n, m;

    printf("Enter number of pages: ");
    scanf("%d", &n);

    printf("Enter reference string: ");
    for (int i = 0; i < n; i++)
        scanf("%d", &p[i]);

    printf("Enter number of frames: ");
    scanf("%d", &m);

    fifo(p, n, m);
    lru(p, n, m);
    optimal(p, n, m);

    return 0;
}
